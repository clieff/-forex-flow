DATABASE_URL="postgresql://postgres:postgres@localhost:5432/forexflow?connection_limit=1&pool_timeout=20"
AUTH_SECRET="replace-with-a-secure-random-string"
AUTH_TRUST_HOST="true"

# Fuseau horaire métier (Cameroun). À définir aussi dans les variables
# d'environnement de l'hébergeur (Vercel) pour que les bornes de journée
# des rapports/caisse correspondent à l'heure locale.
TZ="Africa/Douala"
